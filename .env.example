# Copie ce fichier en ".env" et remplace les valeurs (ne commite jamais .env)

DISCORD_TOKEN=votre_token_bot_ici
CLIENT_ID=id_application_discord_ici
# ID du serveur = uniquement des chiffres (clic droit sur l’icône du serveur → Copier l’identifiant)
GUILD_ID=

# Railway + MongoDB Atlas (ou plugin Mongo Railway) — obligatoire en production
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
# Optionnel : nom de la base (défaut sayuri_rank)
# MONGO_DB_NAME=sayuri_rank
